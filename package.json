{
  "name": "hone",
  "version": "2.0.1",
  "description": "CLI tool that hones codebases through iterative quality improvement cycles using Claude agents",
  "license": "MIT",
  "module": "src/cli.ts",
  "type": "module",
  "private": true,
  "bin": {
    "hone": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile=build/hone",
    "build:all": "bun run build:macos-arm64 && bun run build:macos-x64 && bun run build:linux-x64 && bun run build:windows-x64",
    "build:macos-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile=build/hone-darwin-arm64",
    "build:macos-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile=build/hone-darwin-x64",
    "build:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile=build/hone-linux-x64",
    "build:windows-x64": "bun build src/cli.ts --compile --target=bun-windows-x64 --outfile=build/hone-windows-x64.exe",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check src/",
    "lint:fix": "bunx biome check src/ --write",
    "format": "bunx biome format src/ --write",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4"
  },
  "overrides": {
    "esbuild": "^0.28.0",
    "rollup": "^4.60.2",
    "vite": "^6.4.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
