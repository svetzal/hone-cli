{
  "gates": [
    {
      "name": "typecheck",
      "command": "$HOME/.bun/bin/bunx tsc --noEmit",
      "required": true
    },
    {
      "name": "lint",
      "command": "$HOME/.bun/bin/bunx biome check src/",
      "required": true
    },
    {
      "name": "test",
      "command": "$HOME/.bun/bin/bun test",
      "required": true
    },
    {
      "name": "security",
      "command": "osv-scanner .",
      "required": true
    },
    {
      "name": "build",
      "command": "$HOME/.bun/bin/bun build src/cli.ts --compile --outfile=build/hone",
      "required": true
    },
    {
      "name": "smoke-test",
      "command": "./build/hone --version",
      "required": true
    }
  ]
}
